/target
Cargo.lock
__pycache__/
ios_simulator_screenshot.png
/.wrangler/
/tmp/
# Local onboarding sandbox + auth fixtures. May contain REAL OAuth tokens copied
# from $HOME (see scripts/onboarding_sandbox.sh seed-real-logins). Never commit.
/.tmp/
/.daanio/generated-images/
/telemetry-worker/backups/
target-ttest/
target-ttest*/

# Internal documentation and development/release helpers stay available in the
# local working copy, but are intentionally not published in the public repo.
# The two public installers remain tracked because website deployment and CI
# verify them directly from a fresh checkout.
/docs/
/scripts/*
!/scripts/install.sh
!/scripts/install.ps1

# Stray experiment/debug artifacts at the repo root. Real assets live under
# assets/, ios/, and tests/ and are committed explicitly.
/*.log
/*.avif
/*.mp4
/*.png
